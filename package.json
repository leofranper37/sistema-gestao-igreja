    "dev": "nodemon src/server.js",
    "dev:ctrlf5": "nodemon --watch src --watch public --ext js,json,html,css src/server.js",
    "init:db": "node scripts/init-db.js",
    "check:db": "node scripts/check-db.js",
    "migrate": "node scripts/migrar-schema.js",
    "backup:db": "node scripts/backup-db.js",
    "restore:db": "node scripts/restore-db.js",
    "gatilho:init": "node scripts/gatilho-retomada.js init-today",
    "gatilho:save": "node scripts/gatilho-retomada.js save",
    "gatilho:resume": "node scripts/gatilho-retomada.js resume",
    "stop": "echo 'Use CTRL+C para parar o servidor.'",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
