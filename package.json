    "jsonwebtoken": "^9.0.3",
    "mercadopago": "^2.12.0",
    "mysql2": "^3.17.4",
    "nodemailer": "^6.10.1",
    "nodemon": "^3.1.0",
    "pg": "^8.20.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "winston": "^3.19.0"
