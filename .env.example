# Exemplo de configuração local do projeto.
# Use este arquivo apenas como modelo.
# Em produção na Vercel, configure as variáveis no painel do projeto.

# Porta do servidor
PORT=3001

# Banco local
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ldfp_db
@@ # ============================================================
@@ # OPÇÃO 1: MySQL/MariaDB (Render, Railway, etc)
@@ # ============================================================
@@ # DATABASE_URL=mysql://root:password@host.proxy.rlwy.net:3306/database
@@ # OU use variáveis individuais:
@@ # DB_HOST=host.proxy.rlwy.net
@@ # DB_PORT=3306
@@ # DB_USER=root
@@ # DB_PASSWORD=sua_senha
@@ # DB_NAME=database
@@ 
@@ # ============================================================
@@ # OPÇÃO 2: PostgreSQL (Neon) - RECOMENDADO para Vercel
@@ # ============================================================
@@ # DATABASE_URL=postgresql://user:password@host.neon.tech:5432/database?sslmode=require
@@ # Obtém string em: https://console.neon.tech → seu projeto → Connection String
@@ # Exemplo completo:
@@ # DATABASE_URL=postgresql://user_name:a1b2c3d4@ep-tiny-frost-12345.us-east-1.neon.tech:5432/neondb?sslmode=require
DB_CONNECTION_LIMIT=10

# Alternativa de nome para senha do banco
DB_PASS=

# Railway/Vercel também são aceitos pelo código com estes nomes:
@@ # IMPORTANTE em produção (Vercel):
@@ # - Sempre use DATABASE_URL (uma URL completa)
@@ # - Não use localhost/127.0.0.1
@@ # - APP_BASE_URL é a URL da aplicação, não do banco

# Aplicação
NODE_ENV=development
APP_BASE_URL=http://localhost:3001
APP_PUBLIC_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Segurança
PASSWORD_SALT_ROUNDS=10
JWT_SECRET=troque-esta-chave-em-producao
JWT_EXPIRES_IN=12h

# SMTP opcional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_aplicativo
SMTP_FROM="Seu Nome <seuemail@gmail.com>"

# Integrações opcionais
WHATSAPP_PROVIDER=mock
PAYMENT_BASE_URL=https://pagamento.exemplo.local

