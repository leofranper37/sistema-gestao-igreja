###############################################
# Exemplo de configuração - LDFP
# Copie este arquivo para ".env" e ajuste
###############################################

# Porta do servidor Node
PORT=3001

# Configuração do banco de dados (MySQL/MariaDB)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=ldfp_db
DB_CONNECTION_LIMIT=10

# Alternativa de nome de variável de senha (compatível com o código)
DB_PASS=

# Ambiente de execução
NODE_ENV=development

# Lista de origens permitidas para CORS, separadas por vírgula.
# Deixe em branco para permitir qualquer origem.
CORS_ORIGIN=

# Custo do hash de senha com bcryptjs
PASSWORD_SALT_ROUNDS=10

# Segurança de autenticação JWT
JWT_SECRET=troque-esta-chave-em-producao
JWT_EXPIRES_IN=12h

# URL base da aplicação (caso use no front ou e-mails)
APP_BASE_URL=http://localhost:3001

# Configurações de e-mail (caso venha a usar nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=leopereita31@gmail.com
SMTP_PASS=leo190528
SMTP_FROM="LDFP <no-reply@ldfp.local>"

